<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MovieTelopTranscriber.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:MovieTelopTranscriber.App.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Padding="14"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <AutoSuggestBox
                    Grid.Column="0"
                    PlaceholderText="{x:Bind ViewModel.UiText.PathPlaceholder, Mode=OneWay}"
                    Text="{x:Bind ViewModel.VideoPath, Mode=TwoWay}" />
                <Button Grid.Column="1" MinWidth="88" Command="{x:Bind ViewModel.SelectVideoCommand}" Content="{x:Bind ViewModel.UiText.BrowseButton, Mode=OneWay}" />
                <Button Grid.Column="2" MinWidth="88" Command="{x:Bind ViewModel.StartAnalysisCommand}" Content="{x:Bind ViewModel.UiText.ExtractButton, Mode=OneWay}" />
                <Button Grid.Column="3" MinWidth="88" Command="{x:Bind ViewModel.OpenSettingsOutputCommand}" Content="{x:Bind ViewModel.UiText.SettingsButton, Mode=OneWay}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Bind ViewModel.UiText.InputSection, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.UiText.SupportedFormats, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SupportedFormats, Mode=OneWay}"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Spacing="10">
                            <TextBlock Text="{x:Bind ViewModel.UiText.SettingsSection, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.UiText.FrameInterval, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                <TextBox
                                    Text="{x:Bind ViewModel.FrameIntervalText, Mode=TwoWay}"
                                    ToolTipService.ToolTip="{x:Bind ViewModel.UiText.FrameIntervalSettingDescription, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.UiText.Language, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedLanguageOption, Mode=TwoWay}"
                                    ToolTipService.ToolTip="{x:Bind ViewModel.UiText.LanguageSettingDescription, Mode=OneWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:LanguageOption">
                                            <TextBlock Text="{x:Bind DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.SettingItems, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:SettingItem">
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="8"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="{x:Bind Description}">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind Label}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource AppMetaValueTextStyle}"
                                                    Text="{x:Bind Value}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="10">
                            <TextBlock Text="{x:Bind ViewModel.UiText.StatusSection, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.InfoCards, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:InfoCardItem">
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6"
                                            ToolTipService.ToolTip="{x:Bind Description}">
                                            <StackPanel Spacing="3">
                                                <TextBlock
                                                    Text="{x:Bind Title}"
                                                    Style="{StaticResource AppMetaLabelTextStyle}" />
                                                <TextBlock
                                                    Text="{x:Bind Value}"
                                                    Style="{StaticResource AppMetaValueTextStyle}"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind ViewModel.UiText.PreviewSection, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <ToggleButton
                                Grid.Column="1"
                                IsChecked="{x:Bind ViewModel.ShowTimelineSelection, Mode=TwoWay}"
                                Content="{x:Bind ViewModel.UiText.SyncTimeline, Mode=OneWay}" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            x:Name="PreviewFrameContainer"
                            MinHeight="280"
                            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                            CornerRadius="6"
                            SizeChanged="OnPreviewFrameContainerSizeChanged">
                            <Grid>
                                <Image
                                    x:Name="PreviewFrameImage"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    ImageFailed="OnPreviewFrameImageFailed"
                                    ImageOpened="OnPreviewFrameImageOpened"
                                    Stretch="Uniform" />
                                <Canvas
                                    x:Name="PreviewOverlayCanvas"
                                    IsHitTestVisible="False" />
                                <StackPanel
                                    x:Name="PreviewEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <FontIcon Glyph="&#xE714;" FontSize="32" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        Text="{x:Bind ViewModel.PreviewState, Mode=OneWay}"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource AppSecondaryTextStyle}"
                                        Text="{x:Bind ViewModel.UiText.PreviewShell, Mode=OneWay}"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2" Spacing="6">
                            <TextBlock Text="{x:Bind ViewModel.UiText.SelectedItem, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.SelectedSegmentSummary, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Text="{x:Bind ViewModel.PreviewDetailText, Mode=OneWay}"
                                Style="{StaticResource AppSecondaryTextStyle}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="12">
                        <TextBlock Text="{x:Bind ViewModel.UiText.Timeline, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <ListView
                            Margin="0,28,0,0"
                            ItemsSource="{x:Bind ViewModel.TimelineSegments, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedTimelineSegment, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:TimelineSegment">
                                    <Grid Padding="0,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind RangeLabel}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Text}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource AppSecondaryTextStyle}"
                                            Text="{x:Bind StyleSummary}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Border
                Grid.Column="2"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="{x:Bind ViewModel.UiText.Results, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <ListView
                            Margin="0,28,0,0"
                            ItemsSource="{x:Bind ViewModel.ResultRows, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedResultRow, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ResultRow">
                                    <Border Margin="0,0,0,8" Padding="10" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="6">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind RangeLabel}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind Category}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            </Grid>
                                            <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" />
                                            <TextBlock
                                                Text="{x:Bind Detail}"
                                                Style="{StaticResource AppSecondaryTextStyle}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <StackPanel Grid.Row="1" Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.UiText.Activity, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.ActivityMessage, Mode=OneWay}" />
                        <ProgressBar Minimum="0" Maximum="100" Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" />
                        <StackPanel Spacing="6">
                            <Button Command="{x:Bind ViewModel.RerunFrameExtractionCommand}" Content="{x:Bind ViewModel.UiText.RerunFrames, Mode=OneWay}" HorizontalAlignment="Stretch" />
                            <Button Command="{x:Bind ViewModel.RerunOcrCommand}" Content="{x:Bind ViewModel.UiText.RerunOcr, Mode=OneWay}" HorizontalAlignment="Stretch" />
                            <Button Command="{x:Bind ViewModel.RerunExportCommand}" Content="{x:Bind ViewModel.UiText.ExportOnly, Mode=OneWay}" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <Border
                            Padding="10"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="6">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.UiText.LastFailure, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.LastFailedStageText, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind ViewModel.LastErrorCodeText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.LastErrorMessageText, Mode=OneWay}"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RunLogPathText, Mode=OneWay}"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <InfoBar
            Grid.Row="2"
            IsOpen="True"
            IsClosable="False"
            Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
            Severity="Informational" />
    </Grid>
</Page>
