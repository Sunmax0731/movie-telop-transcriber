<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MovieTelopTranscriber.App.ExportWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieTelopTranscriber.App.Models">
    <Grid Padding="16" RowSpacing="14" Width="680">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Text="Export" Style="{StaticResource AppPageTitleTextStyle}" />
            <TextBlock
                Text="Generated JSON and CSV output paths for the latest run."
                Style="{StaticResource AppSecondaryTextStyle}"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="10">
            <TextBox
                Header="Output directory"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.ExportDirectoryText, Mode=OneWay}"
                TextWrapping="Wrap" />
            <TextBox
                Header="JSON"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.JsonOutputPathText, Mode=OneWay}"
                TextWrapping="Wrap" />
            <TextBox
                Header="Segments CSV"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.SegmentsCsvOutputPathText, Mode=OneWay}"
                TextWrapping="Wrap" />
            <TextBox
                Header="Frames CSV"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.FramesCsvOutputPathText, Mode=OneWay}"
                TextWrapping="Wrap" />
            <TextBox
                Header="Run log"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.RunLogPathText, Mode=OneWay}"
                TextWrapping="Wrap" />
            <TextBox
                Header="Run summary"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.RunSummaryPathText, Mode=OneWay}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2">
            <TextBlock Text="Latest result list" Style="{StaticResource AppSectionTitleTextStyle}" />
            <ListView
                Margin="0,30,0,0"
                ItemsSource="{x:Bind ViewModel.ResultRows, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ResultRow">
                        <Border
                            Margin="0,0,0,8"
                            Padding="10"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="6">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind RangeLabel}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                <TextBlock Text="{x:Bind Category}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Text="{x:Bind Detail}"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>
