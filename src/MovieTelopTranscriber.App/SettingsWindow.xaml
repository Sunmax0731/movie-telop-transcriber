<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MovieTelopTranscriber.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieTelopTranscriber.App.Models">
    <ScrollViewer
        HorizontalScrollBarVisibility="Auto"
        HorizontalScrollMode="Auto"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto">
        <StackPanel Padding="16" Spacing="16" MinWidth="900">
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Bind ViewModel.UiText.SettingsButton, Mode=OneWay}" Style="{StaticResource AppPageTitleTextStyle}" />
                <TextBlock
                    Text="{x:Bind ViewModel.UiText.SettingsOutputWindowDescription, Mode=OneWay}"
                    Style="{StaticResource AppSecondaryTextStyle}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.UiText.SettingsSection, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <ComboBox
                            Header="{x:Bind ViewModel.UiText.Language, Mode=OneWay}"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedLanguageOption, Mode=TwoWay}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.UiText.LanguageSettingDescription, Mode=OneWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:LanguageOption">
                                    <TextBlock Text="{x:Bind DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <StackPanel Spacing="6">
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.OutputDirectory, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                Text="{x:Bind ViewModel.OutputRootDirectoryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.OutputSettingDescription, Mode=OneWay}" />
                            <Button
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.SelectOutputRootDirectoryCommand}"
                                Content="{x:Bind ViewModel.UiText.BrowseButton, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="PaddleOCR" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <CheckBox
                            Content="OCR 前処理を有効にする"
                            IsChecked="{x:Bind ViewModel.PaddlePreprocessEnabled, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ToolTipService.ToolTip="フルフレームを拡大せず、コントラスト補正とシャープ化を適用してから OCR に渡します。" />
                        <CheckBox
                            Content="シャープ化"
                            IsChecked="{x:Bind ViewModel.PaddleSharpenEnabled, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ToolTipService.ToolTip="細い文字や小さい仮名を認識しやすくするために画像全体をシャープ化します。" />

                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                Grid.Row="0"
                                Grid.Column="0"
                                Header="コントラスト"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="1.1"
                                Text="{x:Bind ViewModel.PaddleContrastText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="OCR 前のコントラスト補正倍率です。1.0 が補正なしです。" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="0"
                                Header="text_det_thresh"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetThreshText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="PaddleOCR の文字検出閾値です。空欄の場合は PaddleOCR の既定値を使います。" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Header="text_det_box_thresh"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetBoxThreshText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="PaddleOCR の検出ボックス閾値です。空欄の場合は PaddleOCR の既定値を使います。" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="0"
                                Header="text_det_unclip_ratio"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetUnclipRatioText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="検出ボックスの広げ方を調整します。空欄の場合は PaddleOCR の既定値を使います。" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Header="text_det_limit_side_len"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetLimitSideLenText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="検出時の入力画像サイズ上限です。空欄の場合は PaddleOCR の既定値を使います。" />
                            <CheckBox
                                Grid.Row="3"
                                Grid.Column="0"
                                Content="文字方向分類"
                                IsChecked="{x:Bind ViewModel.PaddleUseTextlineOrientation, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                ToolTipService.ToolTip="縦書きや回転した文字列が多い場合に試す設定です。" />
                            <CheckBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Content="文書ゆがみ補正"
                                IsChecked="{x:Bind ViewModel.PaddleUseDocUnwarping, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                ToolTipService.ToolTip="撮影文書向けのゆがみ補正です。通常の動画テロップでは OFF を既定にします。" />
                        </Grid>
                    </StackPanel>
                </Border>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
