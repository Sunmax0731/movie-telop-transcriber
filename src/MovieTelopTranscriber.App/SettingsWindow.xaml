<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MovieTelopTranscriber.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieTelopTranscriber.App.Models">
    <ScrollViewer>
        <StackPanel Padding="16" Spacing="14" Width="500">
            <StackPanel Spacing="4">
                <TextBlock Text="Settings" Style="{StaticResource AppPageTitleTextStyle}" />
                <TextBlock
                    Text="Main window remains available while this window is open."
                    Style="{StaticResource AppSecondaryTextStyle}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TextBox
                Header="Frame interval (sec)"
                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                Text="{x:Bind ViewModel.FrameIntervalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBox
                Header="OCR engine"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.OcrEngineText, Mode=OneWay}" />

            <TextBox
                Header="Current video"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.VideoPath, Mode=OneWay}"
                TextWrapping="Wrap" />

            <TextBox
                Header="Work directory"
                IsReadOnly="True"
                Text="{x:Bind ViewModel.WorkDirectoryText, Mode=OneWay}"
                TextWrapping="Wrap" />

            <StackPanel Spacing="8">
                <TextBlock Text="Current setting summary" Style="{StaticResource AppSectionTitleTextStyle}" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.SettingItems, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:SettingItem">
                            <Border
                                Margin="0,0,0,8"
                                Padding="10"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Label}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                    <TextBlock Text="{x:Bind Value}" Style="{StaticResource AppMetaValueTextStyle}" />
                                    <TextBlock
                                        Text="{x:Bind Description}"
                                        Style="{StaticResource AppSecondaryTextStyle}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
