<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MovieTelopTranscriber.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieTelopTranscriber.App.Models">
    <ScrollViewer
        HorizontalScrollBarVisibility="Auto"
        HorizontalScrollMode="Auto"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto">
        <StackPanel Padding="16" Spacing="16" MinWidth="1280">
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Bind ViewModel.UiText.SettingsButton, Mode=OneWay}" Style="{StaticResource AppPageTitleTextStyle}" />
                <TextBlock
                    Text="{x:Bind ViewModel.UiText.SettingsOutputWindowDescription, Mode=OneWay}"
                    Style="{StaticResource AppSecondaryTextStyle}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="440" />
                    <ColumnDefinition Width="440" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Bind ViewModel.UiText.SettingsSection, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.FrameInterval, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                Text="{x:Bind ViewModel.FrameIntervalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.FrameIntervalSettingDescription, Mode=OneWay}" />

                            <ComboBox
                                Header="{x:Bind ViewModel.UiText.Language, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedLanguageOption, Mode=TwoWay}"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.LanguageSettingDescription, Mode=OneWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:LanguageOption">
                                        <TextBlock Text="{x:Bind DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBox
                                Header="{x:Bind ViewModel.UiText.OcrEngine, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.OcrEngineText, Mode=OneWay}" />

                            <TextBox
                                Header="{x:Bind ViewModel.UiText.CurrentVideo, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.VideoPath, Mode=OneWay}"
                                TextWrapping="Wrap" />

                            <TextBox
                                Header="{x:Bind ViewModel.UiText.WorkDirectory, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.WorkDirectoryText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.UiText.CurrentSettingSummary, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.SettingItems, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:SettingItem">
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6"
                                            ToolTipService.ToolTip="{x:Bind Description}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{x:Bind Label}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                                <TextBlock Text="{x:Bind Value}" Style="{StaticResource AppMetaValueTextStyle}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="PaddleOCR" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <CheckBox
                            Content="OCR 前処理を有効にする"
                            IsChecked="{x:Bind ViewModel.PaddlePreprocessEnabled, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ToolTipService.ToolTip="フルフレームを自動で拡大、コントラスト補正、シャープ化してから OCR に渡します。" />
                        <CheckBox
                            Content="シャープ化"
                            IsChecked="{x:Bind ViewModel.PaddleSharpenEnabled, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ToolTipService.ToolTip="細い文字や小さい仮名を認識しやすくするために画像全体をシャープ化します。" />

                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                Grid.Row="0"
                                Grid.Column="0"
                                Header="拡大率"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="1.5"
                                Text="{x:Bind ViewModel.PaddleUpscaleText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="OCR 前にフルフレームを拡大する倍率です。1.0 から 4.0 の範囲で反映します。" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Header="コントラスト"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="1.1"
                                Text="{x:Bind ViewModel.PaddleContrastText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="OCR 前のコントラスト補正倍率です。1.0 が補正なしです。" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="0"
                                Header="text_det_thresh"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetThreshText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="PaddleOCR の文字検出閾値です。空欄の場合は PaddleOCR の既定値を使います。" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Header="text_det_box_thresh"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetBoxThreshText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="PaddleOCR の検出ボックス閾値です。空欄の場合は PaddleOCR の既定値を使います。" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="0"
                                Header="text_det_unclip_ratio"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetUnclipRatioText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="検出ボックスの広げ方を調整します。空欄の場合は PaddleOCR の既定値を使います。" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Header="text_det_limit_side_len"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                PlaceholderText="既定"
                                Text="{x:Bind ViewModel.PaddleTextDetLimitSideLenText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ToolTipService.ToolTip="検出時の入力画像サイズ上限です。空欄の場合は PaddleOCR の既定値を使います。" />
                            <CheckBox
                                Grid.Row="3"
                                Grid.Column="0"
                                Content="文字方向分類"
                                IsChecked="{x:Bind ViewModel.PaddleUseTextlineOrientation, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                ToolTipService.ToolTip="縦書きや回転した文字列が多い場合に試す設定です。" />
                            <CheckBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Content="文書ゆがみ補正"
                                IsChecked="{x:Bind ViewModel.PaddleUseDocUnwarping, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                ToolTipService.ToolTip="撮影文書向けのゆがみ補正です。通常の動画テロップでは OFF を既定にします。" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Bind ViewModel.UiText.ExportInfoTitle, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.OutputDirectory, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.ExportDirectoryText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.JsonOutput, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.JsonOutputPathText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.SegmentsCsv, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.SegmentsCsvOutputPathText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.FramesCsv, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.FramesCsvOutputPathText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.RunLog, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.RunLogPathText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.RunSummary, Mode=OneWay}"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.RunSummaryPathText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.UiText.LatestResultList, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                            <ListView
                                MaxHeight="260"
                                ItemsSource="{x:Bind ViewModel.ResultRows, Mode=OneWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ResultRow">
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{x:Bind RangeLabel}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                                <TextBlock Text="{x:Bind Category}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" />
                                                <TextBlock
                                                    Text="{x:Bind Detail}"
                                                    Style="{StaticResource AppSecondaryTextStyle}"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
