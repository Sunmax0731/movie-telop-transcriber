<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MovieTelopTranscriber.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieTelopTranscriber.App.Models">
    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto">
        <StackPanel Padding="16" Spacing="16" MinWidth="760">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.UiText.SettingsSection, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <ComboBox
                            Header="{x:Bind ViewModel.UiText.Language, Mode=OneWay}"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedLanguageOption, Mode=TwoWay}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.UiText.LanguageSettingDescription, Mode=OneWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:LanguageOption">
                                    <TextBlock Text="{x:Bind DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <StackPanel Spacing="4" ToolTipService.ToolTip="{x:Bind ViewModel.UiText.FrameIntervalSettingDescription, Mode=OneWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind ViewModel.UiText.FrameInterval, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.FrameIntervalText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                            </Grid>
                            <Slider
                                Minimum="0.25"
                                Maximum="10"
                                StepFrequency="0.25"
                                TickFrequency="1"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                SnapsTo="StepValues"
                                Value="{x:Bind ViewModel.FrameIntervalValue, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBox
                                Header="{x:Bind ViewModel.UiText.OutputDirectory, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                Text="{x:Bind ViewModel.OutputRootDirectoryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.OutputSettingDescription, Mode=OneWay}" />
                            <Button
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.SelectOutputRootDirectoryCommand}"
                                Content="{x:Bind ViewModel.UiText.BrowseButton, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" />
                        </StackPanel>
                        <Button
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.ResetSettingsDefaultsCommand}"
                            Content="{x:Bind ViewModel.UiText.ResetDefaultsButton, Mode=OneWay}"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.UiText.DetectionSettingsTitle, Mode=OneWay}" Style="{StaticResource AppSectionTitleTextStyle}" />
                        <CheckBox
                            Content="{x:Bind ViewModel.UiText.PaddlePreprocessLabel, Mode=OneWay}"
                            IsChecked="{x:Bind ViewModel.PaddlePreprocessEnabled, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddlePreprocessDescription, Mode=OneWay}" />
                        <CheckBox
                            Content="{x:Bind ViewModel.UiText.PaddleSharpenLabel, Mode=OneWay}"
                            IsChecked="{x:Bind ViewModel.PaddleSharpenEnabled, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleSharpenDescription, Mode=OneWay}" />

                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Spacing="4"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleContrastDescription, Mode=OneWay}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ViewModel.UiText.PaddleContrastLabel, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PaddleContrastText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                                </Grid>
                                <Slider Minimum="0.1" Maximum="4" StepFrequency="0.1" TickFrequency="1" IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" SnapsTo="StepValues" Value="{x:Bind ViewModel.PaddleContrastValue, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Spacing="4"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleTextDetThreshDescription, Mode=OneWay}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ViewModel.UiText.PaddleTextDetThreshLabel, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PaddleTextDetThreshText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="1" StepFrequency="0.01" TickFrequency="0.25" IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" Value="{x:Bind ViewModel.PaddleTextDetThreshValue, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Spacing="4"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleTextDetBoxThreshDescription, Mode=OneWay}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ViewModel.UiText.PaddleTextDetBoxThreshLabel, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PaddleTextDetBoxThreshText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="1" StepFrequency="0.01" TickFrequency="0.25" IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" Value="{x:Bind ViewModel.PaddleTextDetBoxThreshValue, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Spacing="4"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleTextDetUnclipRatioDescription, Mode=OneWay}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ViewModel.UiText.PaddleTextDetUnclipRatioLabel, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PaddleTextDetUnclipRatioText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                                </Grid>
                                <Slider Minimum="0.1" Maximum="10" StepFrequency="0.1" TickFrequency="1" IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" Value="{x:Bind ViewModel.PaddleTextDetUnclipRatioValue, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="1"
                                Spacing="4"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleTextDetLimitSideLenDescription, Mode=OneWay}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ViewModel.UiText.PaddleTextDetLimitSideLenLabel, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PaddleTextDetLimitSideLenText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                                </Grid>
                                <Slider Minimum="16" Maximum="4096" StepFrequency="16" TickFrequency="512" IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" SnapsTo="StepValues" Value="{x:Bind ViewModel.PaddleTextDetLimitSideLenValue, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="3"
                                Grid.Column="0"
                                Spacing="4"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleMinTextSizeDescription, Mode=OneWay}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ViewModel.UiText.PaddleMinTextSizeLabel, Mode=OneWay}" Style="{StaticResource AppMetaLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PaddleMinTextSizeText, Mode=OneWay}" Style="{StaticResource AppSecondaryTextStyle}" />
                                </Grid>
                                <Slider Minimum="0" Maximum="200" StepFrequency="1" TickFrequency="20" IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}" Value="{x:Bind ViewModel.PaddleMinTextSizeValue, Mode=TwoWay}" />
                            </StackPanel>
                            <CheckBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Content="{x:Bind ViewModel.UiText.PaddleUseTextlineOrientationLabel, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.PaddleUseTextlineOrientation, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleUseTextlineOrientationDescription, Mode=OneWay}" />
                            <CheckBox
                                Grid.Row="4"
                                Grid.Column="1"
                                Content="{x:Bind ViewModel.UiText.PaddleUseDocUnwarpingLabel, Mode=OneWay}"
                                IsChecked="{x:Bind ViewModel.PaddleUseDocUnwarping, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.CanInteract, Mode=OneWay}"
                                ToolTipService.ToolTip="{x:Bind ViewModel.UiText.PaddleUseDocUnwarpingDescription, Mode=OneWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
